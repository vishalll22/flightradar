# --- OpenSky Network credentials ---
# Preferred: OAuth2 client credentials. Create an API client in your OpenSky
# account (https://opensky-network.org/) and paste the values here.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Legacy basic auth (only if your account still supports it). Leave blank if you
# use OAuth2 above.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# How often to poll OpenSky (seconds). Keep >= 8 to respect rate limits.
POLL_INTERVAL=8

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
FLIGHT_TTL=60

# --- Server ---
# How often the WebSocket server pushes region deltas to clients (seconds).
PUSH_INTERVAL=2
